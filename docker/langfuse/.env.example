# Langfuse Web/Worker 必须使用相同的精确版本。
LANGFUSE_VERSION=3.223.0
POSTGRES_VERSION=17
REDIS_VERSION=7
# 官方 Compose 对 ClickHouse 和 MinIO 使用滚动镜像；需要可重复部署时可改为验证过的精确标签。
CLICKHOUSE_VERSION=latest
MINIO_VERSION=latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=
REDIS_AUTH=
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=
NEXTAUTH_SECRET=
SALT=
# 必须是 32 字节（64 个十六进制字符）。
ENCRYPTION_KEY=

TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

LANGFUSE_PORT=3100
MINIO_API_PORT=9190
MINIO_CONSOLE_PORT=9191
PUBLIC_BIND_ADDR=127.0.0.1
INTERNAL_BIND_ADDR=127.0.0.1
LANGFUSE_PUBLIC_URL=http://localhost:3100
MINIO_PUBLIC_URL=http://localhost:9190
