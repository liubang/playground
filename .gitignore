# ==============================================================================
# Bazel
# ==============================================================================
# Bazel symlinks (workspace name may vary, so use wildcard)
/bazel-*
# Bazel compile commands extractor: external symlink
/external
# Generated compile_commands.json for clangd
/compile_commands.json

# ==============================================================================
# IDE / Editor
# ==============================================================================
# JetBrains (IntelliJ, GoLand, CLion, etc.)
.idea/
# Eclipse
**/.classpath
**/.project
**/.settings/
# VS Code
.vscode/
# Toolbox
**/*.toolbox/

# ==============================================================================
# OS generated files
# ==============================================================================
.DS_Store
Thumbs.db

# ==============================================================================
# C / C++
# ==============================================================================
# clangd index cache
/.cache/
# Compiled objects
*.o
*.obj
*.a
*.so
*.dylib

# ==============================================================================
# Java
# ==============================================================================
# Maven build output
**/target/
# Compiled classes
*.class

# ==============================================================================
# Go
# ==============================================================================
go/vendor/*
!go/vendor/.gitkeep
*.out

# ==============================================================================
# Python
# ==============================================================================
python/.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ==============================================================================
# Python / Manim
# ==============================================================================
python/manim/manimations/media/

# ==============================================================================
# LaTeX
# ==============================================================================
*.aux
*.fdb_latexmk
*.fls
*.log
*.synctex.gz
*.xdv

# ==============================================================================
# TLA+ / TLC model checker
# ==============================================================================
**/tla/states/
**/tla/*_TTrace_*.tla
**/tla/*_TTrace_*.bin
**/tla/*.pdf

# ==============================================================================
# Docker development environments
# ==============================================================================
# Generated secrets and local settings (keep .env.example files)
/docker/**/.env
/docker/**/.env.local
/docker/**/*.pem
/docker/**/*.key
/docker/**/secrets.yaml
/docker/**/password.db

# Hermes runtime state, caches, sessions, downloaded skills, and databases
/docker/hermes/data/

# Dependencies downloaded by bootstrap.sh
/docker/bigdata/hive/lib/*.jar
/docker/bigdata/spark/jars/*.jar

# Extension deployment artifacts built from java/pl/bigdata
/docker/bigdata/extensions/spark/jars/*.jar
/docker/bigdata/extensions/trino/plugins/*/

# Local third-party source checkout
/docker/openclaw/

# Local-only tool settings
/docker/.claude/settings.local.json

# ==============================================================================
# Misc
# ==============================================================================
*.old
.codegraph/
