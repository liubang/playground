# ==============================================================================
# Bazel
# ==============================================================================
# Bazel symlinks (workspace name may vary, so use wildcard)
/bazel-*
# Bazel compile commands extractor: external symlink
/external
# Generated compile_commands.json for clangd
/compile_commands.json

# ==============================================================================
# IDE / Editor
# ==============================================================================
# JetBrains (IntelliJ, GoLand, CLion, etc.)
.idea/
# Eclipse
**/.classpath
**/.project
**/.settings/
# VS Code
.vscode/
# Toolbox
**/*.toolbox/

# ==============================================================================
# OS generated files
# ==============================================================================
.DS_Store
Thumbs.db

# ==============================================================================
# C / C++
# ==============================================================================
# clangd index cache
/.cache/
# Compiled objects
*.o
*.obj
*.a
*.so
*.dylib

# ==============================================================================
# Java
# ==============================================================================
# Maven build output
**/target/
# Compiled classes
*.class

# ==============================================================================
# Go
# ==============================================================================
go/vendor/*
!go/vendor/.gitkeep
*.out

# ==============================================================================
# Python
# ==============================================================================
python/.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ==============================================================================
# Python / Manim
# ==============================================================================
python/manim/manimations/media/

# ==============================================================================
# LaTeX
# ==============================================================================
*.aux
*.fdb_latexmk
*.fls
*.log
*.synctex.gz
*.xdv

# ==============================================================================
# TLA+ / TLC model checker
# ==============================================================================
**/tla/states/
**/tla/*_TTrace_*.tla
**/tla/*_TTrace_*.bin
**/tla/*.pdf

# ==============================================================================
# Misc
# ==============================================================================
*.old
.codegraph/
