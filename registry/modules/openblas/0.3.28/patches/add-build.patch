+load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")
+
+package(default_visibility = ["//visibility:public"])
+
+filegroup(
+    name = "all_srcs",
+    srcs = glob(
+        ["**"],
+        exclude = ["bazel-*/**"],
+    ),
+)
+
+cmake(
+    name = "openblas",
+    cache_entries = {
+        "BUILD_SHARED_LIBS": "OFF",
+        "BUILD_WITHOUT_LAPACK": "OFF",
+        "NOFORTRAN": "ON",
+        "NO_FORTRAN": "ON",
+        "C_LAPACK": "ON",
+        "USE_OPENMP": "OFF",
+        "BUILD_TESTING": "OFF",
+    },
+    lib_source = ":all_srcs",
+    out_static_libs = ["libopenblas.a"],
+    visibility = ["//visibility:public"],
+)
